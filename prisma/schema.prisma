// Prisma schema for Florai (SQLite)
// To generate client: pnpm prisma generate
// To create DB schema: pnpm prisma db push (or migrate dev)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // stores a bcrypt hash — hashing is handled in application code
  name      String?
  flowers   Flower[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Flower {
  id                     String   @id // coming from db.json; not auto-generated
  name                   String
  imageUrl               String?
  colors                 String   // JSON-serialised string[] (SQLite has no Json type)
  type                   String
  wholesalePrice         Float
  retailPrice            Float
  supplier               String?
  origin                 String?
  season                 String   // JSON-serialised string[] (SQLite has no Json type)
  availability           String   // "seasonal" | "always" | "limited"
  quantityOnHand         Int      @default(0)
  stemsPerBunch          Int?     // How many stems per supplier bunch
  stemLengthCm           Int?     // Typical stem length in cm
  fragranceLevel         String?  // "none" | "light" | "moderate" | "strong"
  toxicity               String?  // "safe" | "mild" | "toxic"
  vaseLifeDays           Int?     // Minimum expected vase life in days
  careInstructions       String?
  notes                  String?
  complementaryFlowerIds String   // JSON-serialised string[] (SQLite has no Json type)
  userId                 String?
  user                   User?    @relation(fields: [userId], references: [id])
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}
