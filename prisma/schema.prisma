// Prisma schema for Florai (SQLite)
// To generate client: pnpm prisma generate
// To create DB schema: pnpm prisma db push (or migrate dev)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // stores a bcrypt hash — hashing is handled in application code
  name      String?
  flowers   Flower[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Flower {
  id                     String   @id // coming from db.json; not auto-generated
  name                   String
  imageUrl               String?
  colors                 String   // JSON-serialised string[] (SQLite has no Json type)
  type                   String
  wholesalePrice         Float
  retailPrice            Float
  supplier               String?
  origin                 String?
  season                 String   // JSON-serialised string[] (SQLite has no Json type)
  availability           String   // "seasonal" | "always" (string in db.json)
  quantityOnHand         Int      @default(0)
  vaseLife               String?  // string in db.json (e.g., "7-10 days")
  careInstructions       String?
  notes                  String?
  complementaryFlowerIds String   // JSON-serialised string[] (SQLite has no Json type)
  userId                 String?
  user                   User?    @relation(fields: [userId], references: [id])
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}
