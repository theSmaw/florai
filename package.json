{
  "name": "untitled1",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "json-server --watch db.json --port 3001",
    "type-check": "tsc --noEmit",
    "build": "pnpm run type-check && vite build",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "task:start": "bash scripts/start-task.sh",
    "task:publish": "bash scripts/publish-branch.sh",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:studio": "prisma studio",
    "prisma:seed": "prisma db seed",
    "prisma:test": "tsx scripts/list-flowers.ts",
    "pr:create": "bash scripts/publish-branch.sh 'chore(prisma): add Prisma ORM setup'",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:ci": "start-server-and-test 'pnpm dev & pnpm dev:api' http://localhost:5173 'cypress:run'",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{js,ts,json}\""
  },
  "devDependencies": {
    "@storybook/addon-actions": "^8.6.15",
    "@storybook/addon-essentials": "^8.6.15",
    "@storybook/addon-interactions": "^8.6.15",
    "@storybook/react": "^8.6.15",
    "@storybook/react-vite": "^8.6.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.24",
    "cypress": "^13.17.0",
    "json-server": "^0.17.4",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prisma": "^5.16.1",
    "start-server-and-test": "^2.1.3",
    "storybook": "^8.6.15",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@prisma/client": "^5.16.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/themes": "^3.1.0",
    "@reduxjs/toolkit": "^2.11.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.1",
    "redux": "^5.0.1"
  },
