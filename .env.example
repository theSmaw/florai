# Supabase connection — copy to .env.local and fill in from `supabase status`
#
# Local development (run `supabase start` then `supabase status` to get these values):
#   VITE_SUPABASE_URL=http://127.0.0.1:54321
#   VITE_SUPABASE_ANON_KEY=sb_publishable_...   (shown as "Publishable" in supabase status)
#   VITE_SUPABASE_SERVICE_ROLE_KEY=sb_secret_... (shown as "Secret" in supabase status)
#
# Production: paste values from your Supabase project's API settings page.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_SERVICE_ROLE_KEY=
